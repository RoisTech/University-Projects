@startuml
title Cyber Defense SOC Platform — Diagrama de Sequência
title Caso de Uso: Executar Playbook de Contenção

autonumber

actor "AnalistaSOC" as Analista

boundary "IncidenteController" as Controller
control "PlaybookEngine" as Engine
entity "Incidente" as Incidente
participant "FirewallService" as Firewall

== Início do Fluxo ==

Analista -> Controller : executarPlaybook(incidenteId)
activate Controller

Controller -> Engine : executarContencao(incidenteId)
activate Engine

Engine -> Incidente : obterDados()
activate Incidente
Incidente --> Engine : dadosIncidente
deactivate Incidente

Engine -> Engine : validarParametros()

Engine -> Firewall : bloquearIP(ipAlvo)
activate Firewall

alt Contenção executada com sucesso

    Firewall --> Engine : confirmacaoBloqueio()
    deactivate Firewall

    Engine -> Incidente : alterarEstado("Mitigado")
    activate Incidente
    Incidente --> Engine : estadoAtualizado
    deactivate Incidente

    Engine --> Controller : sucesso("Contenção executada")
    deactivate Engine

    Controller --> Analista : operação concluída
    deactivate Controller

else Timeout/Falha no Firewall

    Firewall --> Engine : TimeoutException
    deactivate Firewall

    Engine -> Incidente : alterarEstado("Falha na Contenção")
    activate Incidente
    Incidente --> Engine : estadoAtualizado
    deactivate Incidente

    Engine --> Controller : erro("Falha no Firewall")
    deactivate Engine

    Controller --> Analista : aviso de erro
    deactivate Controller

end

@enduml